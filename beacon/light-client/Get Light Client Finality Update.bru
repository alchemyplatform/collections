  seq: 3
}

get {
  url: https://eth-mainnetbeacon.g.alchemy.com/v2/{{api_key}}/eth/v1/beacon/light_client/finality_update
  body: none
  auth: none
}

docs {
  ## Get Light Client Finality Update

