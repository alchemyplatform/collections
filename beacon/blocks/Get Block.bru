meta {
  name: Get Block
  type: http
  seq: 1
}

get {
  url: https://eth-mainnetbeacon.g.alchemy.com/v2/{{api_key}}/eth/v2/beacon/blocks/:block_id
  body: none
  auth: none
}

params:path {
  block_id: head
}

docs {
  ## Get Block

  Returns the full beacon block for the given block ID. The block ID can be a slot number, a hex-encoded block root, or one of the special values: `head`, `genesis`, `finalized`.

  **Note:** The response is large. The structure below is abbreviated.

  ### Response (200)
