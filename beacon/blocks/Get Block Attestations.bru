meta {
  name: Get Block Attestations
  type: http
  seq: 3
}

get {
  url: https://eth-mainnetbeacon.g.alchemy.com/v2/{{api_key}}/eth/v1/beacon/blocks/:block_id/attestations
  body: none
  auth: none
}

params:path {
  block_id: head
}

docs {
  ## Get Block Attestations

  Returns the attestations included in the requested block.

