meta {
  name: Get Blob Sidecars
  type: http
  seq: 1
}

get {
  url: https://eth-mainnetbeacon.g.alchemy.com/v2/{{api_key}}/eth/v1/beacon/blob_sidecars/:block_id
  body: none
  auth: none
}

params:query {
  ~indices: 0,1
}

params:path {
  block_id: head
}

docs {
  ## Get Blob Sidecars
  
  Returns the blob sidecars for the given block ID. Optionally filter by blob indices using the `indices` query parameter.
  
  ### Query Parameters
  - `indices` (optional): Comma-separated list of blob indices to return (e.g., `0,1`)
  
