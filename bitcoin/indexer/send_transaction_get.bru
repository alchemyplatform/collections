  name: Send Transaction (GET)
  type: http
  seq: 8
}

get {
  url: https://bitcoin-mainnet.g.alchemy.com/v2/{{api_key}}/api/v2/sendtx/:hex
  body: none
  auth: none
}

params:path {
  hex: 
}

docs {
  Broadcasts a signed raw transaction to the Bitcoin network via a GET request.

  Parameters:
  1. hex (string, required) - Hex-encoded raw transaction bytes.

  Returns a result string containing the transaction ID of the broadcast transaction.

  Use send_transaction_post for large transactions that exceed URL length limits.
}
