  name: refreshNftMetadata
  type: http
  seq: 14
}

post {
  url: https://eth-mainnet.g.alchemy.com/nft/v3/{{api_key}}/refreshNftMetadata
  body: json
  auth: none
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "contractAddress": "0xe785E82358879F061BC3dcAC6f0444462D4b5330",
    "tokenId": "44"
